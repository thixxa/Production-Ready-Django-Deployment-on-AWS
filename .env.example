# Copy to .env for local overrides (never commit the real .env file)

# A long, random string - generate your own for production, e.g.:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-in-production

# Comma-separated list of allowed hostnames.
# In production this will be the ALB's DNS name (Phase 4).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to "true" only after HTTPS is configured on the load balancer (Phase 5)
DJANGO_USE_HTTPS=false
